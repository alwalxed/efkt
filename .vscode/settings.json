{
  "files.exclude": {
    "**/.git": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "README.md,pnpm-lock.yaml,.gitignore,.prettierrc.json,tsconfig.json,LICENSE,bun.lock,biome.json,.npmrc,release.md"
  },
  "cSpell.words": [
    "Activedescendant",
    "alwalxed",
    "efkt",
    "Focusable",
    "Noninteractive",
    "Tabindex"
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true
}
